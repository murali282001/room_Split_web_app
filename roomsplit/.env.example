# ── App ──────────────────────────────────────────────────────────────
APP_NAME=RoomSplit
APP_ENV=development          # development | staging | production
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=roomsplit
POSTGRES_PASSWORD=roomsplit
POSTGRES_DB=roomsplit
DATABASE_URL=postgresql+asyncpg://roomsplit:roomsplit@postgres:5432/roomsplit
DATABASE_URL_SYNC=postgresql+psycopg2://roomsplit:roomsplit@postgres:5432/roomsplit

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OTP ──────────────────────────────────────────────────────────────
OTP_PROVIDER=console         # console (dev) | twilio (prod)
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_10MIN=3

# ── Twilio (set when OTP_PROVIDER=twilio) ────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Frontend ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:80"]

# ── Celery ───────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
