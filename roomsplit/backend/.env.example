# Copy this to .env and fill in your values

APP_NAME=RoomSplit
APP_ENV=development
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Database
DATABASE_URL=postgresql+asyncpg://roomsplit:roomsplit@localhost:5432/roomsplit
DATABASE_URL_SYNC=postgresql+psycopg2://roomsplit:roomsplit@localhost:5432/roomsplit

# Redis
REDIS_URL=redis://localhost:6379/0

# OTP — set to "twilio" in production
OTP_PROVIDER=console
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_10MIN=3

# Twilio (only needed if OTP_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Frontend
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:80"]

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
